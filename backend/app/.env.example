# Copy to .env in this folder (or use backend/.env / repo-root .env — see env_loader.py).
# Get a key: https://cloud.browser-use.com/settings?tab=api-keys

BROWSER_USE_API_KEY=bu_your_key_here

# Optional: HTTP timeout (seconds) for POST /sessions while cloud browsers start (default 180).
# BROWSER_USE_HTTP_TIMEOUT=180

# Optional: pause between session creates when starting multiple agents in one API call (default 0.35).
# BROWSER_USE_AGENT_STAGGER_S=0.35

# Optional: max wall-clock seconds per agent (default 60). Cloud session timeout uses whole minutes (min 1).
# BROWSER_USE_AGENT_MAX_SECONDS=60

# Optional: Gemini topo post-processing (requires google-genai in requirements.txt).
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
